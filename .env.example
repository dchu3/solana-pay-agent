# Required: Google Gemini API key
GEMINI_API_KEY=your-gemini-api-key

# Optional: Gemini model to use (default: gemini-3.1-flash-lite-preview)
# GEMINI_MODEL=gemini-3.1-flash-lite-preview

# Required if REMOTE_MCP_URL is not set: Path to the compiled solana-x402-mcp server entry point
# Use MCP_SERVER_PATH for a local stdio MCP server, or REMOTE_MCP_URL for a remote one.
MCP_SERVER_PATH=../solana-x402-mcp/dist/index.js

# Optional: URL of a remote MCP server (StreamableHTTP transport).
# When set, MCP_SERVER_PATH is not required. x402 payments are handled automatically.
# REMOTE_MCP_URL=http://localhost:4022/mcp

# Required: Solana wallet private key (base58-encoded, passed to MCP server)
SOLANA_PRIVATE_KEY=your-base58-private-key

# Optional: Solana network (mainnet or devnet; "mainnet-beta" is also accepted)
# SOLANA_NETWORK=devnet

# Optional: Custom Solana RPC URL (passed to MCP server)
# SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional: Telegram bot mode (required for `npm run start:telegram`)
# Get a bot token from @BotFather on Telegram
# TELEGRAM_BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11
# Restrict the bot to a single chat ID (get yours by messaging @userinfobot)
# TELEGRAM_CHAT_ID=123456789
